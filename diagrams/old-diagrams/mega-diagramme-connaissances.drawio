        <mxCell id="bench-cpu" value="&lt;b&gt;🔴 CPU (Ryzen 9 — port 11435)&lt;/b&gt; · qwen3:30b-a3b MoE · ctx 64K · ~5 min · Réflexion profonde uniquement" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#e74c3c;strokeWidth=2;fontSize=10;fontColor=#333;align=left;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="60" y="260" width="740" height="25" as="geometry" />
        </mxCell>
        <mxCell id="zone-decisions" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="80" width="720" height="250" as="geometry" />
        </mxCell>
        <mxCell id="zone-decisions-label" value="📋 Décisions Clés" style="text;html=1;strokeColor=none;fillColor=#fef9e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#f39c12;" vertex="1" parent="1">
          <mxGeometry x="840" y="65" width="200" height="18" as="geometry" />
        </mxCell>
        <mxCell id="decisions-content" value="&lt;b&gt;🎯 Choix modèles :&lt;/b&gt;&lt;br&gt;• N1.5 qwen2.5-coder:14b 🏆 meilleur code + drawio&lt;br&gt;• N1 qwen3.5-4b pour routeur (ultra-rapide, suffisant pour classif)&lt;br&gt;• N4 deepseek-v4-flash en cloud pour le complexe&lt;br&gt;&lt;br&gt;&lt;b&gt;💰 Tarification freelance :&lt;/b&gt;&lt;br&gt;• TJM 400€/j (long terme) · 600€/j (court terme)&lt;br&gt;• Tarifs solidaires pour associations&lt;br&gt;• Client principal : cloud (reflectas.fr)&lt;br&gt;&lt;br&gt;&lt;b&gt;🏛️ Structure :&lt;/b&gt;&lt;br&gt;• CAE Élan Créateur (~30€/mois compta incluse)&lt;br&gt;• Démarrage freelance : juillet 2026&lt;br&gt;&lt;br&gt;&lt;b&gt;🔧 Architecture retenue :&lt;/b&gt;&lt;br&gt;• Pipeline hybride local/cloud (Routeur→Cascade→Juge)&lt;br&gt;• Drawio MCP comme canal privilégié&lt;br&gt;• Skills + Mémoire pour persistance du savoir&lt;br&gt;• Profile Malek01 : modèle local qwen2.5-coder:14b + drawio&lt;br&gt;&lt;br&gt;&lt;b&gt;🌐 Communication :&lt;/b&gt; LinkedIn &gt; site web (malek-idri-303a0613)&lt;br&gt;Pas de flyers. Site web à faire si besoin." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#f39c12;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="860" y="100" width="680" height="210" as="geometry" />
        </mxCell>
        <mxCell id="zone-dash" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebdef0;strokeColor=#8e44ad;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="350" width="740" height="200" as="geometry" />
        </mxCell>
        <mxCell id="zone-dash-label" value="📈 Dashboards &amp; Scripts Sauvegardés" style="text;html=1;strokeColor=none;fillColor=#ebdef0;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#8e44ad;" vertex="1" parent="1">
          <mxGeometry x="40" y="335" width="310" height="18" as="geometry" />
        </mxCell>
        <mxCell id="dash-content" value="&lt;b&gt;Scripts de benchmark (gardés dans workspace/) :&lt;/b&gt;&lt;br&gt;• &lt;i&gt;benchmark_all_final.py&lt;/i&gt; — benchmark complet tous modèles&lt;br&gt;• &lt;i&gt;benchmark_dashboard_final.py&lt;/i&gt; — dashboard Plotly interactif&lt;br&gt;• &lt;i&gt;benchmark_viz_final.py&lt;/i&gt; — visualisation avancée&lt;br&gt;• &lt;i&gt;benchmark_ollama.py&lt;/i&gt; — benchmark Ollama standardisé&lt;br&gt;• &lt;i&gt;benchmark_speed_65k.py&lt;/i&gt; — test vitesse contexte 65K&lt;br&gt;&lt;br&gt;&lt;b&gt;Autres scripts système :&lt;/b&gt;&lt;br&gt;• &lt;i&gt;ollama_switcher.py&lt;/i&gt; — interface de bascule de modèles (port 8503)&lt;br&gt;• &lt;i&gt;drawio-proxy.py&lt;/i&gt; — proxy TCP pour drawio MCP (port 6002)&lt;br&gt;• &lt;i&gt;env-switch.sh&lt;/i&gt; — script bascule d'environnement&lt;br&gt;• Scripts docx — édition in-place (edit_docx.py, generate_doc.py, analyse_docx.py)&lt;br&gt;• 11 HTML dashboards — visualisations de benchmarks (gardés comme références)&lt;br&gt;• 25 scripts benchmark intermédiaires — supprimés (nettoyage 16/06/2026)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#8e44ad;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="60" y="365" width="700" height="170" as="geometry" />
        </mxCell>
        <mxCell id="zone-stats" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="840" y="350" width="720" height="200" as="geometry" />
        </mxCell>
        <mxCell id="zone-stats-label" value="🧹 Nettoyage du 16/06/2026" style="text;html=1;strokeColor=none;fillColor=#d5f5e3;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#27ae60;" vertex="1" parent="1">
          <mxGeometry x="840" y="335" width="260" height="18" as="geometry" />
        </mxCell>
        <mxCell id="stats-content" value="&lt;b&gt;État final après ménage :&lt;/b&gt;&lt;br&gt;• Sessions DB : 78.1 Mo (45 Mo récupérés!), 260 sessions, 9091 messages&lt;br&gt;• 163 sessions cron supprimées&lt;br&gt;• VACUUM effectué sur la base SQLite&lt;br&gt;&lt;br&gt;&lt;b&gt;Profils supprimés :&lt;/b&gt;&lt;br&gt;• cloud_deepseek_v4_flash (7.8 Mo)&lt;br&gt;• freelance (14 Mo)&lt;br&gt;• vie_perso (11 Mo)&lt;br&gt;&lt;br&gt;&lt;b&gt;Fichiers supprimés :&lt;/b&gt;&lt;br&gt;• 25 scripts benchmark intermédiaires&lt;br&gt;• 2 scripts shell obsolètes&lt;br&gt;• 4 fichiers test (drawio, HTML)&lt;br&gt;• 10 JSON de benchmarks bruts&lt;br&gt;• 1 profil résiduel (7.8 Mo)&lt;br&gt;&lt;br&gt;&lt;b&gt;Mémoire :&lt;/b&gt; 97% → 66% (735 chars libérés, fusionnée en 5 entrées)&lt;br&gt;&lt;b&gt;Final :&lt;/b&gt; 1 profil actif (default), workspace ~1.7 Mo / ~30 fichiers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#27ae60;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="860" y="365" width="680" height="170" as="geometry" />
        </mxCell>
        <mxCell id="legende" value="&lt;b&gt;Résumé pour le nouveau profil Malek01&lt;/b&gt;&lt;hr&gt;🏆 Modèle local principal : &lt;b&gt;qwen2.5-coder:14b&lt;/b&gt; (8.7 t/s, ctx 32K) — drawio + code&lt;br&gt;⚡ Routeur : qwen3.5-4b-agent-opt (80 t/s)&lt;br&gt;☁️ Cloud : deepseek-v4-flash (pour le complexe uniquement)&lt;br&gt;📐 Canal privilégié : &lt;b&gt;drawio MCP&lt;/b&gt; pour tous les schémas&lt;br&gt;🧠 Savoir : Skills (procédures) + Mémoire (faits durables)&lt;br&gt;🎨 Préférence : HTML pur / Plotly / drawio (PAS Streamlit)&lt;br&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;📅 Créé le 16/06/2026 · Méga-Diagramme v1.0 — 5 pages&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#bdc3c7;strokeWidth=1;fontSize=9;fontColor=#555;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="570" width="600" height="150" as="geometry" />
        </mxCell>
      </root>
