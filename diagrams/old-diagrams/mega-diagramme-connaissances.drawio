        <mxCell id="complexe-target" value="&lt;b&gt;🔴 COMPLEXE → Cloud&lt;/b&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;deepseek-v4-flash (OpenRouter)&lt;br&gt;~5s · Payant (mais puissant)&lt;br&gt;Débogage avancé, recherche&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#e74c3c;strokeWidth=2;fontSize=10;fontColor=#333;align=left;verticalAlign=top;" vertex="1" parent="1">
