        <mxCell id="bench-igpu" value="&lt;b&gt;🔵 iGPU (Radeon 780M — port 11436)&lt;/b&gt; · qwen2.5:14b · ctx 64K · ~30-100s · Fallback quand GPU occupé" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#2980b9;strokeWidth=2;fontSize=10;fontColor=#333;align=left;verticalAlign=middle;" vertex="1" parent="1">
