        <mxCell id="cascade-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fef9e7;strokeColor=#f39c12;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="820" y="200" width="740" height="310" as="geometry" />
        </mxCell>
        <mxCell id="cascade-zone-label" value="📊 2. CASCADE PROGRESSIVE — Escalade automatique" style="text;html=1;strokeColor=none;fillColor=#fef9e7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;fontColor=#f39c12;" vertex="1" parent="1">
          <mxGeometry x="820" y="185" width="400" height="18" as="geometry" />
        </mxCell>
        <mxCell id="cascade-flow" value="&lt;b&gt;N1 (4B GPU)&lt;/b&gt;&lt;br&gt;score ≥ 4/5 → ✅ STOP&lt;br&gt;score &amp;lt; 4 → ⬇ escalade&lt;br&gt;&lt;hr&gt;&lt;b&gt;N1.5 (14B coder GPU)&lt;/b&gt;&lt;br&gt;score ≥ 4/5 → ✅ STOP&lt;br&gt;score &amp;lt; 4 → ⬇ escalade&lt;br&gt;&lt;hr&gt;&lt;b&gt;N2 (14B iGPU)&lt;/b&gt;&lt;br&gt;score ≥ 4/5 → ✅ STOP&lt;br&gt;score &amp;lt; 4 → ⬇ escalade&lt;br&gt;&lt;hr&gt;&lt;b&gt;N3 (30B CPU)&lt;/b&gt;&lt;br&gt;score ≥ 4/5 → ✅ STOP&lt;br&gt;score &amp;lt; 4 → ⬇ escalade&lt;br&gt;&lt;hr&gt;&lt;b&gt;N4 (Cloud DeepSeek)&lt;/b&gt;&lt;br&gt;Réponse finale garantie" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#f39c12;strokeWidth=1;fontSize=9;fontColor=#333;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="850" y="215" width="300" height="280" as="geometry" />
        </mxCell>
        <mxCell id="juge-zone" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f4ecf7;strokeColor=#8e44ad;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="510" width="680" height="160" as="geometry" />
        </mxCell>
        <mxCell id="juge-zone-label" value="⚖️ 3. JUGE — Évaluation Qualité" style="text;html=1;strokeColor=none;fillColor=#f4ecf7;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=13;fontStyle=1;fontColor=#8e44ad;" vertex="1" parent="1">
          <mxGeometry x="40" y="495" width="250" height="18" as="geometry" />
        </mxCell>
        <mxCell id="juge-box" value="&lt;b&gt;⚖️ Juge : Qwen2.5:1.5B&lt;/b&gt;&lt;hr&gt;&lt;table&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Pertinence&lt;/b&gt;&lt;/td&gt;&lt;td&gt;⭐ 1-5&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Exactitude&lt;/b&gt;&lt;/td&gt;&lt;td&gt;⭐ 1-5&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Hallucinations&lt;/b&gt;&lt;/td&gt;&lt;td&gt;⚠️ 1-5 (1 = pas d'hallu)&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Usage&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Après chaque réponse cascade&lt;/td&gt;&lt;/tr&gt;&lt;tr&gt;&lt;td&gt;&lt;b&gt;Décision&lt;/b&gt;&lt;/td&gt;&lt;td&gt;Score ≥4 → ✅ · &amp;lt;4 → ⬇ escalade&lt;/td&gt;&lt;/tr&gt;&lt;/table&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebdef0;strokeColor=#8e44ad;strokeWidth=2;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="70" y="525" width="280" height="130" as="geometry" />
        </mxCell>
        <mxCell id="juge-result" value="&lt;b&gt;📊 Résultat remonté à toi&lt;/b&gt;&lt;hr&gt;&lt;font style='font-size:10px'&gt;Exemple :&lt;br&gt;🔀 Routeur → CODE&lt;br&gt;📊 Cascade → N1.5 (score 4.5/5)&lt;br&gt;⚖️ Juge → 4.2/5 ✅&lt;br&gt;💡 Économie : ~10K tokens cloud&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;strokeWidth=2;fontSize=10;fontColor=#333;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="390" y="525" width="300" height="130" as="geometry" />
        </mxCell>
        <mxCell id="arrow-cascade-juge" value="résultat + score" style="endArrow=classic;html=1;fontSize=10;edgeStyle=orthogonalEdgeStyle;curved=1;rounded=1;strokeColor=#8e44ad;strokeWidth=2;fontColor=#8e44ad;fontStyle=1;" edge="1" parent="1">
