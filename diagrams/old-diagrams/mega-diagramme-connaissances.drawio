        <mxCell id="simple-target" value="&lt;b&gt;🟢 SIMPLE → N1 (4B GPU)&lt;/b&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;qwen3.5-4b-agent-opt:latest&lt;br&gt;Context 4K · 80 t/s · Gratuit&lt;br&gt;Réponse immédiate&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;strokeWidth=2;fontSize=10;fontColor=#333;align=left;verticalAlign=top;" vertex="1" parent="1">
