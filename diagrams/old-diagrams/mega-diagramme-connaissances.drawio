        <mxCell id="svc-mcp" value="&lt;b&gt;🧩 MCP Servers&lt;/b&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;Config: config.yaml[mcp_servers]&lt;br&gt;Drawio : npx @next-ai-drawio/mcp-server&lt;br&gt;Hérité par les subagents (delegation.inherit_mcp_toolsets=true)&lt;br&gt;Disponible pour tous les profils&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#8e44ad;strokeWidth=2;fontSize=9;fontColor=#333;align=left;verticalAlign=top;" vertex="1" parent="1">
