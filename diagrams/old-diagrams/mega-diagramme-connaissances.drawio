        </mxCell>
        <mxCell id="legende" value="&lt;b&gt;Légende&lt;/b&gt;&lt;hr&gt;🟢 SIMPLE → N1 qwen3.5-4b (80 t/s)&lt;br&gt;🔵 CODE → N1.5 qwen2.5-coder:14b 🥇 (8.7 t/s)&lt;br&gt;🔴 COMPLEXE → N4 Cloud DeepSeek (payant)&lt;br&gt;🟡 Cascade → escalade jusqu'à confiance ≥4/5&lt;br&gt;🟣 Juge → évaluation qualité par Qwen2.5:1.5B&lt;br&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;💡 Utilisation : &lt;i&gt;routeur:&lt;/i&gt; &lt;i&gt;cascade:&lt;/i&gt; &lt;i&gt;pipeline:&lt;/i&gt;&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#bdc3c7;strokeWidth=1;fontSize=10;fontColor=#555;align=left;verticalAlign=top;" vertex="1" parent="1">
