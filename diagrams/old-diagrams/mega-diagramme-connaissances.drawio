        <mxCell id="bench-gpu-coder" value="&lt;b&gt;🥇 qwen2.5-coder:14b&lt;/b&gt; · 14.8B Q4_K_M · ctx 32768 · &lt;b&gt;8.7 t/s&lt;/b&gt; · ⭐ Tâches CODE + drawio XML + algorithmes" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#2980b9;strokeWidth=2;fontSize=10;fontColor=#333;align=left;verticalAlign=middle;" vertex="1" parent="1">
