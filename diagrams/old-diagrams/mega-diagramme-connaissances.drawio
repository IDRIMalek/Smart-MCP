          <mxGeometry x="40" y="65" width="220" height="18" as="geometry" />
        </mxCell>
        <mxCell id="wf-drawio-steps" value="&lt;b&gt;Étapes :&lt;/b&gt;&lt;br&gt;1️⃣ skill_view('drawio-mcp-setup') ← charger la skill&lt;br&gt;2️⃣ mcp_drawio_start_session() ← lancer session navigateur&lt;br&gt;3️⃣ Création : mcp_drawio_create_new_diagram(xml) ← DESTRUCTIF (remplace tout)&lt;br&gt;4️⃣ Ajout page : mcp_drawio_add_page(name, xml) ← AJOUTE sans toucher les autres&lt;br&gt;5️⃣ Édition : mcp_drawio_get_diagram() → edit_diagram(opérations)&lt;br&gt;6️⃣ Export : mcp_drawio_export_diagram(path)&lt;br&gt;&lt;hr&gt;&lt;b&gt;⚠️ Pièges :&lt;/b&gt;&lt;br&gt;• Toujours get_diagram AVANT edit_diagram (perte des modifs utilisateur sinon)&lt;br&gt;• create_new_diagram = COMPLETEMENT DESTRUCTIF (toutes les pages + modifs non sauvées)&lt;br&gt;• Le proxy utilise 0.0.0.0:6002 (accessible réseau local — ufw configuré)&lt;br&gt;• format auto-détecté depuis l'extension (.drawio, .png, .svg)&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#f1c40f;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="60" y="100" width="700" height="190" as="geometry" />
        </mxCell>
        <mxCell id="zone-wf-doc" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e8f4f8;strokeColor=#4a90d9;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="80" width="760" height="230" as="geometry" />
        </mxCell>
        <mxCell id="wf-doc-label" value="📝 Documents .docx — Édition In-Place" style="text;html=1;strokeColor=none;fillColor=#e8f4f8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#4a90d9;" vertex="1" parent="1">
          <mxGeometry x="800" y="65" width="320" height="18" as="geometry" />
        </mxCell>
        <mxCell id="wf-doc-steps" value="&lt;b&gt;Workflow Business Plan :&lt;/b&gt;&lt;br&gt;1️⃣ Prendre le .docx existant (template avec logo&amp;structure)&lt;br&gt;2️⃣ Éditer IN-PLACE avec python-docx (terminal, pas sandbox)&lt;br&gt;3️⃣ Conserver TOUTES les questions du template (elles existent — ne pas recréer)&lt;br&gt;&lt;hr&gt;&lt;b&gt;Sections souvent oubliées :&lt;/b&gt;&lt;br&gt;• Autodiagnostic&lt;br&gt;• Concurrents / clients en attente / CA prévisionnel&lt;br&gt;• Revenus actuels (ARE ~1700€/mois)&lt;br&gt;• Situation familiale (marié, Vezin le Coquet 35)&lt;br&gt;&lt;hr&gt;&lt;b&gt;💰 CAE :&lt;/b&gt; Élan Créateur, ~30€/mois compta incluse (pas de comptable séparé)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#4a90d9;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="820" y="100" width="720" height="190" as="geometry" />
        </mxCell>
        <mxCell id="zone-wf-cuda" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fadbd8;strokeColor=#e74c3c;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="330" width="740" height="170" as="geometry" />
        </mxCell>
        <mxCell id="wf-cuda-label" value="🧪 CUDA Verification — PIÈGE CRITIQUE" style="text;html=1;strokeColor=none;fillColor=#fadbd8;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#e74c3c;" vertex="1" parent="1">
          <mxGeometry x="40" y="315" width="310" height="18" as="geometry" />
        </mxCell>
        <mxCell id="wf-cuda-steps" value="&lt;b&gt;⛔ Ce qu'il NE FALLAIT PAS faire :&lt;/b&gt;&lt;br&gt;grep 'cuda|nvml' /proc/*/maps → FAUX ! Match le chemin du binaire, pas les vraies libs CUDA&lt;br&gt;&lt;br&gt;&lt;b&gt;✅ Ce qu'il FAUT faire :&lt;/b&gt;&lt;br&gt;grep 'cuda_v13|ggml-cuda|libcuda|libcublas|libcudart|libnvml' sur &lt;b&gt;TOUS&lt;/b&gt; les llama-server PIDs&lt;br&gt;&lt;br&gt;&lt;b&gt;🎯 Pourquoi :&lt;/b&gt;&lt;br&gt;Ollama lance plusieurs processus llama-server. Un seul utilise CUDA activement. Vérifier head seulement = faux négatif.&lt;br&gt;&lt;br&gt;&lt;b&gt;🔧 Fix NVIDIA :&lt;/b&gt; drop-in nopersistence-fix.conf pour nvidia-persistenced.service" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#e74c3c;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="60" y="345" width="700" height="140" as="geometry" />
        </mxCell>
        <mxCell id="zone-wf-viz" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ebdef0;strokeColor=#8e44ad;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="330" width="760" height="170" as="geometry" />
        </mxCell>
        <mxCell id="wf-viz-label" value="📊 Dashboard &amp; Visualisation" style="text;html=1;strokeColor=none;fillColor=#ebdef0;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#8e44ad;" vertex="1" parent="1">
          <mxGeometry x="800" y="315" width="250" height="18" as="geometry" />
        </mxCell>
        <mxCell id="wf-viz-steps" value="&lt;b&gt;Préférences de Malek :&lt;/b&gt;&lt;br&gt;✅ HTML/JS pur (Plotly, pas Streamlit — écran noir détesté)&lt;br&gt;✅ Dashboards interactifs (speed bar, radar qualité, heatmap)&lt;br&gt;✅ Benchmarks MESURÉS (pas estimés) — Plotly interactif&lt;br&gt;✅ Schémas drawio multi-page comme interface mentale principale&lt;br&gt;✅ Diagrammes d'architecture, pipeline, workflow&lt;br&gt;❌ PAS de Streamlit (écran noir, lent, inadapté)&lt;br&gt;❌ PAS de suppositions — toujours mesurer&lt;br&gt;&lt;br&gt;&lt;b&gt;Itératif :&lt;/b&gt; préférer des suggestions concrètes, pas des questions ouvertes&lt;br&gt;&lt;b&gt;Transparence :&lt;/b&gt; donner des estimations réalistes et justifiées" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#8e44ad;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="820" y="345" width="720" height="140" as="geometry" />
        </mxCell>
        <mxCell id="zone-wf-skills" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5f5e3;strokeColor=#27ae60;strokeWidth=2;dashed=1;" vertex="1" parent="1">
          <mxGeometry x="40" y="520" width="1520" height="160" as="geometry" />
        </mxCell>
        <mxCell id="wf-skills-label" value="🧠 Gestion des Skills &amp; Mémoire" style="text;html=1;strokeColor=none;fillColor=#d5f5e3;align=center;verticalAlign=middle;whiteSpace=wrap;rounded=1;fontSize=14;fontStyle=1;fontColor=#27ae60;" vertex="1" parent="1">
          <mxGeometry x="40" y="505" width="260" height="18" as="geometry" />
        </mxCell>
        <mxCell id="wf-skills-rules" value="&lt;b&gt;Règles d'or :&lt;/b&gt;&lt;br&gt;1️⃣ Toujours charger les skills qui matchent (skill_view) avant de coder — elles contiennent les chemins exacts, les pièges et les workflows éprouvés&lt;br&gt;2️⃣ Skills &gt; mémoire pour les procédures (10K+ chars vs 2200 chars limités)&lt;br&gt;3️⃣ Mémoire = faits durables (nom, préférences, infras). PAS de logs, statuts, progresses&lt;br&gt;4️⃣ Compacter et fusionner régulièrement (user profil 68%, memory notes 66%)&lt;br&gt;5️⃣ Skills list : append 'skill_view(name)' automatiquement si pertinent&lt;br&gt;6️⃣ Patching : si une skill est incomplète/erronée, la patcher IMMÉDIATEMENT (skill_manage patch)&lt;br&gt;7️⃣ skills_list + skill_view sont le premier réflexe avant toute action&lt;br&gt;&lt;hr&gt;&lt;b&gt;Skills clés pour Malek :&lt;/b&gt; cascade-optim · router-optim · pipeline-optim · drawio-mcp-setup · hermes-agent · debugging · test-driven-development" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff;strokeColor=#27ae60;strokeWidth=1;fontSize=9;fontColor=#333;align=left;verticalAlign=top;overflow=hidden;" vertex="1" parent="1">
          <mxGeometry x="60" y="535" width="1480" height="130" as="geometry" />
        </mxCell>
        <mxCell id="legende" value="&lt;b&gt;Légende&lt;/b&gt;&lt;hr&gt;🟡 Drawio MCP — canal privilégié pour les schémas&lt;br&gt;🔵 Documents .docx — édition in-place avec python-docx&lt;br&gt;🔴 CUDA Trap — piège critique à ne jamais reproduire&lt;br&gt;🟣 Visualisation — préférences Plotly / drawio / HTML&lt;br&gt;🟢 Skills &amp; Mémoire — bonnes pratiques&lt;br&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;📅 Créé le 16/06/2026 · Méga-Diagramme v1.0&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f9f9f9;strokeColor=#bdc3c7;strokeWidth=1;fontSize=9;fontColor=#555;align=left;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="60" y="700" width="400" height="130" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
