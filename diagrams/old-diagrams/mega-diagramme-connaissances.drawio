        <mxCell id="code-target" value="&lt;b&gt;🔵 CODE → N1.5 (14B coder GPU) 🥇&lt;/b&gt;&lt;hr&gt;&lt;font style='font-size:9px'&gt;qwen2.5-coder:14b&lt;br&gt;Context 32K · 8.7 t/s · Gratuit&lt;br&gt;Scripts · Drawio XML · Algo&lt;/font&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d6eaf8;strokeColor=#2980b9;strokeWidth=2;fontSize=10;fontColor=#333;align=left;VerticalAlign=top;" vertex="1" parent="1">
