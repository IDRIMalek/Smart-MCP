  <root>
    <mxCell id="0" />
    <mxCell id="1" parent="0" />
    <!-- ==================== TITLE ==================== -->
    <mxCell id="2" value="🧠 HERMES — Architecture, Contextes &amp; Tools" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;fontColor=#e94560;fontSize=14;fontStyle=1;arcSize=10;" vertex="1" parent="1">
      <mxGeometry x="100" y="10" width="600" height="30" as="geometry" />
    </mxCell>
    <mxCell id="3" value="&lt;b&gt;Context windows :&lt;/b&gt;&lt;br&gt;• System prompt (10-30K tokens) : mémoire, user profile, skills, instructions de conduite&lt;br&gt;• Context window (8-131K tokens) : tout ce que vous avez dit + outputs d'outils&lt;br&gt;• Session DB : stockage persistant des conversations (FTS5 pour recherche)&lt;br&gt;&lt;br&gt;&lt;b&gt;Outils clés :&lt;/b&gt;&lt;br&gt;• memory() / skill_manage() / session_search() — mémoire persistante&lt;br&gt;• mcp_drawio_* — diagrammes drawio interactifs&lt;br&gt;• terminal() / write_file() / patch() — exécution système et code" style="text;html=1;strokeColor=none;fillColor=#F8F9FA;align=left;fontSize=9;fontColor=#333;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="40" y="60" width="350" height="200" as="geometry" />
    </mxCell>
    <mxCell id="4" value="&lt;b&gt;Problèmes résolus :&lt;/b&gt;&lt;br&gt;• ✗ PCI remove/rescan (casse le lien PCIe)&lt;br&gt;• ✗ Fallback silencieux Ollama (modèle dérivé inexistant → troncature 2048)&lt;br&gt;• ✗ Modelfile sans num_ctx (défaut 2048 → réponses vides WebUI)&lt;br&gt;• ✓ Modelfile num_ctx≥65536 pour tous les modèles WebUI&lt;br&gt;• ✓ Modèle dérivé créé avant config dans config.yaml" style="text;html=1;strokeColor=none;fillColor=#FFF2CC;align=left;fontSize=9;fontColor=#333;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
      <mxGeometry x="420" y="60" width="350" height="150" as="geometry" />
    </mxCell>
  </root>
</mxGraphModel></diagram><diagram id="buywf6D7PgYwizoDFIXQ" name="⚙️ Optimisation Architecture"><mxGraphModel dx="2667" dy="994" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="2" value="⚙️ OPTIMISATION ARCHITECTURE — Perf &amp; Coûts" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#1a1a2e;strokeColor=#16213e;fontColor=#e94560;fontSize=14;fontStyle=1;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="100" y="10" width="600" height="30" as="geometry" />
        </mxCell>
        <mxCell id="3" value="&lt;b&gt;Optimisations appliquées :&lt;/b&gt;&lt;br&gt;• Compression contexte (threshold=0.65, target=0.35) pour modèles cloud&lt;br&gt;• Modelfile anti-truncation (num_ctx≥65536) pour tous modèles locaux&lt;br&gt;• Keep-alive Ollama 24h (évite reloads coûteux)&lt;br&gt;• Cascade adaptative (4B d'abord, escalade si nécessaire)&lt;br&gt;• Profil local-diagram dédié aux tests (pas de coût API)&lt;br&gt;&lt;br&gt;&lt;b&gt;Objectifs :&lt;/b&gt;&lt;br&gt;• &amp;lt; 5€/mois en API (DeepSeek V4 Flash très économique)&lt;br&gt;• &amp;gt; 200 tests CI sans dépendance LLM&lt;br&gt;• Diagrammes 100% locaux possibles via qwen3.5:9b-hermes" style="text;html=1;strokeColor=none;fillColor=#F8F9FA;align=left;fontSize=9;fontColor=#333;rounded=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="40" y="60" width="350" height="250" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel></diagram><diagram id="kanban" name="📋 Kanban"><mxGraphModel grid="0" page="0" pageWidth="1800" pageHeight="1400" dx="0" dy="0">
