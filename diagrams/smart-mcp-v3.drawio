<mxfile host="app.diagrams.net">
  <diagram id="page-1" name="Smart MCP v3">
    <mxGraphModel>
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        
        <!-- TITRE -->
        <mxCell id="titre" value="Smart MCP — Architecture Hermes (v3)" style="rounded=1;whiteSpace=wrap;html=1;fontSize=16;fontStyle=1;fillColor=#1a1a2e;strokeColor=#16213e;fontColor=#e94560;align=center;" vertex="1" parent="1">
          <mxGeometry x="30" y="10" width="1060" height="35" as="geometry"/>
        </mxCell>
        
        <!-- ZONE A : UTILISATEUR + HERMES -->
        <mxCell id="zone-a" value="ZONE A — Interaction via Hermes Chat" style="text;html=1;fontSize=10;fontColor=#16213e;align=left;whiteSpace=wrap;rounded=1;fillColor=#e8f0fe;strokeColor=#4285f4;verticalLabelPosition=top;labelPosition=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="30" y="55" width="320" height="240" as="geometry"/>
        </mxCell>
        
        <mxCell id="f1" value="[F1] Toi (Utilisateur)&#10;Tu tapes en francais dans Hermes Chat :&#10;&quot;Dessine un carre rouge&quot;&#10;&#10;Tu ✅ ou ❌ le resultat visuellement" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#fff3bf;strokeColor=#e9c46a;fontColor=#7c5e00;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="70" width="140" height="70" as="geometry"/>
        </mxCell>
        
        <mxCell id="f2" value="[F2] Hermes Agent&#10;Recoit ton message dans le chat&#10;&#10;Tools Hermes :&#10;  - mcp_smart_mcp_* (notre MCP)&#10;  - mcp_drawio_create* (direct)&#10;  - search_files, terminal, etc.&#10;&#10;Skills :&#10;  - smart-mcp skill (guide)&#10;&#10;= Appelle le tool Smart MCP" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#e8f0fe;strokeColor=#4285f4;fontColor=#1a237e;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="155" width="150" height="130" as="geometry"/>
        </mxCell>
        
        <!-- C1: F1 vers F2 -->
        <mxCell id="c1" value="[C1] Phrase en francais" style="endArrow=classic;html=1;fontSize=8;fontColor=#808080;exitX=0.5;exitY=1;entryX=0.5;entryY=0;strokeColor=#A0A0A0;" edge="1" parent="1" source="f1" target="f2">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        
        <!-- ZONE B : SMART MCP SERVER -->
        <mxCell id="zone-b" value="ZONE B — Smart MCP Server (Python, registre comme MCP natif dans Hermes)" style="text;html=1;fontSize=10;fontColor=#1b4332;align=left;whiteSpace=wrap;rounded=1;fillColor=#d8f3dc;strokeColor=#2d6a4f;verticalLabelPosition=top;labelPosition=center;verticalAlign=top;" vertex="1" parent="1">
          <mxGeometry x="380" y="55" width="320" height="640" as="geometry"/>
        </mxCell>
        
        <mxCell id="f3" value="[F3] Smart MCP — Interface&#10;Registre dans config.yaml Hermes :&#10;&#10;mcpServers:&#10;  smart-mcp:&#10;    command: python&#10;    args: smart_mcp_server.py&#10;&#10;Outil expose : smart_mcp_process()" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#d8f3dc;strokeColor=#2d6a4f;fontColor=#1b4332;align=left;" vertex="1" parent="1">
          <mxGeometry x="395" y="70" width="290" height="85" as="geometry"/>
        </mxCell>
        
        <mxCell id="f4" value="[F4] 1. Classification&#10;Qwen 9B local determine :&#10;type:shape-simple&#10;key_elements:[carre,rouge]&#10;Jamais de fallback cloud" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#fff3bf;strokeColor=#e9c46a;fontColor=#7c5e00;align=left;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="175" width="145" height="65" as="geometry"/>
        </mxCell>
        
        <mxCell id="f5" value="[F5] 2. RAG Search&#10;ChromeDB semantique :&#10;- Vectorise la description&#10;- Cosine similarity : top 3&#10;- Retourne 3 XML exemples" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#fff3bf;strokeColor=#e9c46a;fontColor=#7c5e00;align=left;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="260" width="145" height="65" as="geometry"/>
        </mxCell>
        
        <mxCell id="f6" value="[F6] 3. XML Generation&#10;&quot;Voici 3 exemples XML,&#10;adapte-les pour un carre rouge&quot;&#10;&#10;Essaie LOCAL [C11] d abord&#10;Si XML invalide : CLOUD [C12]" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#fff3bf;strokeColor=#e9c46a;fontColor=#7c5e00;align=left;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="345" width="145" height="75" as="geometry"/>
        </mxCell>
        
        <mxCell id="f7" value="[F7] 4. Draw.io Execution&#10;Appelle draw.io MCP :&#10;create_new_diagram(xml)&#10;= Diagramme dans navigateur" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#fff3bf;strokeColor=#e9c46a;fontColor=#7c5e00;align=left;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="445" width="145" height="55" as="geometry"/>
        </mxCell>
        
        <mxCell id="f17" value="[F17] 5. Validation auto (VLM) NOUVEAU&#10;2 modes :&#10;&#10;A) TOI (manuel) : regardes, ✅/❌&#10;&#10;B) VLM (auto) : Moondream/Llava&#10;  capture le rendu - compare&#10;  a la phrase originale - score&#10;  Si score > 80% : valide ✅" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#fff3bf;strokeColor=#e9c46a;fontColor=#7c5e00;align=left;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="525" width="145" height="85" as="geometry"/>
        </mxCell>
        
        <mxCell id="f8" value="[F8] 6. Apprentissage&#10;UNIQUEMENT si valide ✅ :&#10;add_pattern(description, xml)&#10;= ChromaDB s enrichit !" style="rounded=1;whiteSpace=wrap;html=1;fontSize=8;fontStyle=0;fillColor=#D0D0D0;strokeColor=#A0A0A0;fontColor=#808080;align=left;arcSize=10;" vertex="1" parent="1">
          <mxGeometry x="395" y="635" width="145" height="55" as="geometry"/>
        </mxCell>
        
